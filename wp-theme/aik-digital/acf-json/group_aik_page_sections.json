                "layout_aik_steps": {
                    "key": "layout_aik_steps",
                    "name": "steps",
                    "label": "Steps (How-To / Order Process)",
                    "display": "block",
                    "instructions": "Numbered step cards (e.g. \"How to Order Your aik Card\") — a fixed set of steps you enter directly, not real WordPress Posts. Don't use the News layout for this; News pulls from Posts and renders date/Read More/See More, which doesn't match this section's design.",
                    "sub_fields": [
                        {
                            "key": "field_aik_steps_heading",
                            "label": "Heading",
                            "name": "heading",
                            "type": "textarea",
                            "rows": 2,
                            "instructions": "Wrap highlighted words in **double asterisks**.",
                            "default_value": "How to **Order** Your **aik Card**"
                        },
                        {
                            "key": "field_aik_steps_description",
                            "label": "Description",
                            "name": "description",
                            "type": "textarea",
                            "rows": 2
                        },
                        {
                            "key": "field_aik_steps_list",
                            "label": "Steps",
                            "name": "steps_list",
                            "type": "repeater",
                            "layout": "block",
                            "button_label": "Add Step",
                            "min": 0,
                            "max": 0,
                            "instructions": "Renders as numbered cards (01, 02, 03…) in a 3-column row, alternating the accent color every other card — matches the original design automatically, nothing to set per-step for that.",
                            "sub_fields": [
                                {
                                    "key": "field_aik_steps_item_image",
                                    "label": "Image",
                                    "name": "image",
                                    "type": "image",
                                    "return_format": "array",
                                    "preview_size": "medium",
                                    "wrapper": { "width": "25" }
                                },
                                {
                                    "key": "field_aik_steps_item_title",
